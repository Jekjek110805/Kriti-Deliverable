# ─────────────────────────────────────────────────────────────────────────────
# Kriti — GSC Opportunity Finder · Environment template
# Copy to ".env" and fill in. ALL vars below are OPTIONAL.
# The core Stage 1A analysis (CSV/XLSX upload → opportunities) is pure Python
# and runs with ZERO configuration. The vars below only enable optional extras.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
# Port the server binds to. Cloud Run injects this automatically; defaults to 8080.
PORT=8080

# ── LiteLLM (optional — AI narrative/H2/FAQ enrichment) ──────────────────────
# If unset, analysis still completes; enrichment text is simply skipped.
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_MODEL=fast-model
# Alternative to LITELLM_API_KEY: path to a file containing the key.
LITELLM_KEY_FILE=/tmp/kriti-backend/config/litellm_key.txt

# ── Google Search Console live API (optional — CSV upload is the default) ─────
# GSC requires an OAuth service-account JSON, NOT a plain API key.
# Leave blank to use CSV/XLSX upload.
GSC_API_KEY=
# Must exactly match the verified GSC property, for example:
# https://example.com/ or sc-domain:example.com
GSC_SITE_URL=
GSC_CREDENTIALS_PATH=config/gsc_credentials.json

# ── SEMrush (optional — keyword volume/difficulty enrichment) ────────────────
# Only read if the SEMrush client is invoked; core flow does not require it.
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us
