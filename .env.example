# ─────────────────────────────────────────────────────────────────────────────
# Kriti — GSC Opportunity Finder · Environment template
# Copy to ".env" and fill in. ALL vars below are OPTIONAL.
# The core Stage 1A analysis (CSV/XLSX upload → opportunities) is pure Python
# and runs with ZERO configuration. The vars below only enable optional extras.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
# Port the server binds to. Cloud Run injects this automatically; defaults to 8080.
PORT=8080

# ── LiteLLM (optional — AI narrative/H2/FAQ enrichment) ──────────────────────
# If unset, analysis still completes; enrichment text is simply skipped.
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_MODEL=fast-model
# Alternative to LITELLM_API_KEY: path to a file containing the key.
LITELLM_KEY_FILE=/tmp/kriti-backend/config/litellm_key.txt

# OpenRouter (optional - Content Writer drafts via Nemotron 3 Super)
# Used by /api/content/write. Keep real keys only in .env, never in git.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=Kriti Content Writer

# ── Google Search Console live API (optional — CSV upload is the default) ─────
# GSC requires an OAuth service-account JSON, NOT a plain API key.
# Leave blank to use CSV/XLSX upload.
GSC_API_KEY=
# Must exactly match the verified GSC property, for example:
# https://example.com/ or sc-domain:example.com
GSC_SITE_URL=
GSC_CREDENTIALS_PATH=config/gsc_credentials.json

# ── SEMrush (optional — keyword volume/difficulty enrichment) ────────────────
# Only read if the SEMrush client is invoked; core flow does not require it.
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us

# CMS publishing (optional - required for remote draft/live publishing)
# For WordPress use CMS_TYPE=wordpress, the site URL or wp-json URL,
# CMS_USERNAME and an Application Password in CMS_API_KEY.
CMS_TYPE=custom
CMS_API_URL=
CMS_API_KEY=
CMS_USERNAME=
CMS_AUTHOR_ID=

# CMS_TYPE=github — for Git-backed CMSs such as TinaCMS (e.g. selfstorage.help).
# Commits a Markdown file to a new branch and opens a pull request; nothing
# is ever committed straight to CMS_GITHUB_BASE_BRANCH. Confirm the target
# repo's real schema (path/format/frontmatter fields) before use — this
# adapter is built for the "post" collection confirmed in devmaai/self-v1's
# tina/config.ts (title, date, excerpt, coverImage, published, body).
# CMS_API_KEY = a fine-grained GitHub PAT scoped to ONLY this repo, with
# Contents: Read/write, Pull requests: Read/write, Metadata: Read.
# CMS_TYPE=github
# CMS_GITHUB_OWNER=devmaai
# CMS_GITHUB_REPO=self-v1
# CMS_GITHUB_BASE_BRANCH=main
# CMS_GITHUB_CONTENT_PATH=content/posts
# CMS_API_KEY=
